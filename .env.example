# ForwardX 端口转发管理面板 - 环境变量配置
# 复制此文件为 .env 并修改对应值

# ==================== 数据库配置 ====================
# SQLite 数据库文件路径
SQLITE_PATH=/data/forwardx.db

# ==================== 安全配置 ====================
# JWT 签名密钥（生产环境务必修改为随机字符串）
JWT_SECRET=change-me-to-a-random-string

# ==================== 应用配置 ====================
# 运行环境
NODE_ENV=production

# 监听端口
PORT=9810

# ==================== Telegram 机器人（可选） ====================
# 从 @BotFather 获取 Bot Token。也可以登录后台后在「系统设置」中填写。
# TELEGRAM_BOT_TOKEN=123456789:replace-with-your-bot-token
# 是否启用长轮询。默认 true，不需要配置 webhook。
# TELEGRAM_BOT_POLLING=true

# ==================== 默认管理员账户 ====================
# 每次启动时 admin 密码会自动重置为此值（默认 admin123）
# 如需自定义默认密码，取消注释并修改下面的值
# ADMIN_PASSWORD=admin123
